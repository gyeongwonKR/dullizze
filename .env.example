# Pexels
PEXELS_API_KEY=

# Pixabay
PIXABAY_API_KEY=

# YouTube (OAuth 토큰은 별도 파일)
YOUTUBE_CLIENT_SECRETS_PATH=./secrets/youtube_client.json
YOUTUBE_TOKEN_PATH=./secrets/youtube_token.json
YOUTUBE_CHANNEL_ID=

# Discord
DISCORD_WEBHOOK_URL=

# 운영 설정
DAILY_BUDGET_USD=2.00
DEFAULT_TONE=흥미로운_사실
DEFAULT_VOICE=ko-KR-SunHiNeural
DEFAULT_VISUAL_MODE=motion_image
DEFAULT_VISUAL_PROVIDER=auto

# BGM (배경음악). 음원은 assets/bgm/<template>.mp3, 없으면 BGM 생략.
BGM_ENABLED=1
BGM_VOLUME_DB=-22
BGM_FADE_MS=800

# 임시 사용자/쿼터 (B4, 인증/결제 전 파일 기반)
DEFAULT_USER_ID=local
DEFAULT_PLAN=free
FREE_MONTHLY_QUOTA=3
BASIC_MONTHLY_QUOTA=30
